{
  "name": "snowflake-dac",
  "version": "0.2.1",
  "description": "Plugin Claude pour DAC Group — accès aux performances paid media Allstate & MNP via Snowflake (spend, leads, CPL, WoW, pacing, anomalies).",
  "repository": "https://github.com/gagnonsebast-sudo/snowflake-dac",
  "skills": "./skills",
  "userConfig": {
    "iris_control_plane_url": {
      "type": "string",
      "title": "IRIS Control Plane URL",
      "description": "URL du Control Plane IrisLabs (fourni par votre admin IRIS)",
      "required": true
    },
    "irislabs_app_id": {
      "type": "string",
      "title": "IrisLabs App ID",
      "description": "App ID du projet IRIS (IRISLABS_APP_ID)",
      "required": true
    },
    "iris_sdk_secret": {
      "type": "string",
      "title": "IRIS SDK Secret",
      "description": "Secret d'authentification IrisLabs (IRIS_SDK_SECRET) — token long-lived",
      "sensitive": true,
      "required": true
    }
  },
  "mcpServers": {
    "snowflake-dac": {
      "command": "python3",
      "args": ["${CLAUDE_PLUGIN_ROOT}/server/snowflake_dac_server.py"],
      "env": {
        "IRIS_CONTROL_PLANE_URL": "${user_config.iris_control_plane_url}",
        "IRISLABS_APP_ID": "${user_config.irislabs_app_id}",
        "IRIS_SDK_SECRET": "${user_config.iris_sdk_secret}"
      }
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pip3 install -q 'mcp[cli]>=1.0.0' 2>/dev/null; exit 0"
          }
        ]
      }
    ]
  }
}
